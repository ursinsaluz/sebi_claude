---
import Layout from '../layouts/Layout.astro';
import TzNav from '../components/TzNav.astro';
import TzFooter from '../components/TzFooter.astro';
import TzArrow from '../components/TzArrow.astro';
import client from '../../tina/__generated__/client';

const response = await client.queries.page({ relativePath: 'home.json' });
const data = response.data.page;
---

<Layout title="titz.cooking — Redesign">
  <div class="tz-root" style="min-height: 2400px; background: var(--paper); position: relative; overflow: hidden;">
    <!-- Nav — sits on hero image -->
    <div style="position: absolute; top: 0; left: 0; right: 0; z-index: 20;">
      <TzNav current="home" dark={true} />
    </div>

    <!-- ─── HERO ─────────────────────────────────── -->
    <section style="position: relative; height: 860px; overflow: hidden; background: #1a1a18;">
      <img src="/img/pinot-11.jpg" alt="" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.78;" />
      <div style="position: absolute; inset: 0; background: linear-gradient(180deg, rgba(26,26,24,0.55) 0%, rgba(26,26,24,0.15) 35%, rgba(26,26,24,0.75) 100%);"></div>

      <!-- Hero text -->
      <div style="position: absolute; left: 56px; right: 56px; bottom: 80px; color: #f4efe7;">
        <div style="display: grid; grid-template-columns: 1fr auto; align-items: flex-end; gap: 48px;">
          <div>
            <div class="tz-eyebrow" style="color: rgba(244,239,231,0.7); margin-bottom: 24px;">
              <span style="color: var(--ember);">●</span>&nbsp;&nbsp;{data.hero?.pretitle}
            </div>
            <h1 class="tz-display" style="font-size: 168px; margin: 0; line-height: 0.88; font-weight: 300;">
              {data.hero?.title1}<br/>
              <span class="it" style="font-style: italic; font-weight: 400;">{data.hero?.titleItalic}</span><br/>
              <span style="color: var(--ember);">{data.hero?.titleEnd}</span>
            </h1>
          </div>
          <div style="text-align: right; padding-bottom: 20px;">
            <p style="font-family: var(--serif); font-size: 20px; font-style: italic; line-height: 1.4; max-width: 340px; font-weight: 300; margin: 0; opacity: 0.9;">
              {data.hero?.subtitle}
            </p>
            <div style="display: flex; gap: 12px; margin-top: 28px; justify-content: flex-end;">
              <a class="tz-btn ember" href="#philo">{data.hero?.ctaPrimary} <TzArrow /></a>
              <a class="tz-btn ghost" href="#kontakt" style="border-color: #f4efe7; color: #f4efe7;">{data.hero?.ctaSecondary}</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Corner marks -->
      <div style="position: absolute; top: 120px; left: 56px; font-family: var(--mono); font-size: 10px; letter-spacing: 0.2em; color: rgba(244,239,231,0.55);">
        46°59′N · 09°31′E
      </div>
      <div style="position: absolute; top: 120px; right: 56px; font-family: var(--mono); font-size: 10px; letter-spacing: 0.2em; color: rgba(244,239,231,0.55); text-align: right;">
        EST. MMXXIV<br/>Nº 001
      </div>
    </section>

    <!-- ─── Auszeichnungen bar ─────────────────────── -->
    <section style="border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); background: var(--paper);">
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); padding: 36px 56px;">
        <!-- Array items hardcoded -->
        <div style="display: flex; align-items: baseline; gap: 20px; padding-left: 0; border-left: none;">
          <div class="tz-display" style="font-size: 64px; font-weight: 300; line-height: 1;">16</div>
          <div>
            <div style="font-family: var(--serif); font-size: 16px; font-style: italic;">GaultMillau</div>
            <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-3); margin-top: 4px;">Punkte 2024</div>
          </div>
        </div>
        <div style="display: flex; align-items: baseline; gap: 20px; padding-left: 40px; border-left: 1px solid var(--rule-soft);">
          <div class="tz-display" style="font-size: 64px; font-weight: 300; line-height: 1;">1★</div>
          <div>
            <div style="font-family: var(--serif); font-size: 16px; font-style: italic;">Michelin Stern</div>
            <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-3); margin-top: 4px;">Verve · Rössli · Jörg Müller</div>
          </div>
        </div>
        <div style="display: flex; align-items: baseline; gap: 20px; padding-left: 40px; border-left: 1px solid var(--rule-soft);">
          <div class="tz-display" style="font-size: 64px; font-weight: 300; line-height: 1;">Bib</div>
          <div>
            <div style="font-family: var(--serif); font-size: 16px; font-style: italic;">Gourmand</div>
            <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-3); margin-top: 4px;">Restaurant Pinot 2024</div>
          </div>
        </div>
        <div style="display: flex; align-items: baseline; gap: 20px; padding-left: 40px; border-left: 1px solid var(--rule-soft);">
          <div class="tz-display" style="font-size: 64px; font-weight: 300; line-height: 1;">20</div>
          <div>
            <div style="font-family: var(--serif); font-size: 16px; font-style: italic;">Jahre</div>
            <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-3); margin-top: 4px;">in der Gourmetgastronomie</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── PHILOSOPHIE ───────────────────────────── -->
    <section id="philo" style="padding: 140px 56px 120px; position: relative;">
      <div style="display: grid; grid-template-columns: 340px 1fr; gap: 80px; margin-bottom: 80px;">
        <div>
          <div class="tz-eyebrow" style="margin-bottom: 16px;">§ 01 — Philosophie</div>
          <div style="font-family: var(--mono); font-size: 11px; color: var(--ink-3); line-height: 1.7;">
            Drei Worte, die alles sagen.<br/>
            Drei Prinzipien, die bleiben.
          </div>
        </div>
        <h2 class="tz-display" style="font-size: 96px; margin: 0; font-weight: 300; max-width: 900px;">
          Kochen ist für mich ein <span class="it" style="font-style: italic;">tiefer Respekt</span> vor dem Ursprung unserer Nahrung.
        </h2>
      </div>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 48px; border-top: 1px solid var(--rule); padding-top: 48px;">
        {data.philosophy?.map((item, index) => (
          <div>
            <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.2em; color: var(--ember); margin-bottom: 24px;">§ 0{index + 1}</div>
            <div style="height: 300px; background: var(--paper-2); margin-bottom: 28px; overflow: hidden;">
              <img src={item.image} alt="" style="width: 100%; height: 100%; object-fit: cover; filter: saturate(0.95);" />
            </div>
            <h3 class="tz-display" style="font-size: 40px; margin: 0 0 12px; font-weight: 400;">{item.title}</h3>
            <p style="font-family: var(--serif); font-size: 17px; font-style: italic; color: var(--ink-2); margin: 0 0 16px; line-height: 1.4;">{item.pretitle}</p>
            <p style="font-size: 14px; line-height: 1.65; color: var(--ink-3); margin: 0;">{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ─── EDITORIAL SPREAD — the chef ───────────── -->
    <section style="background: var(--ink); color: var(--paper); padding: 120px 56px;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;">
        <div style="height: 620px; overflow: hidden; position: relative;">
          <img src="/img/pinot-15.jpg" alt="" style="width: 100%; height: 100%; object-fit: cover;" />
          <div style="position: absolute; bottom: 16px; left: 16px; font-family: var(--mono); font-size: 9px; letter-spacing: 0.2em; color: #f4efe7; opacity: 0.7;">
            FIG. 01 — In der Küche, Restaurant Pinot, Fläsch
          </div>
        </div>
        <div>
          <div class="tz-eyebrow" style="color: var(--ember); margin-bottom: 24px;">§ 02 — Der Koch</div>
          <h2 class="tz-display" style="font-size: 72px; margin: 0; font-weight: 300; line-height: 0.98;">
            Sebastian <span class="it" style="font-style: italic; color: var(--ember);">Titz</span>
          </h2>
          <p style="font-family: var(--serif); font-style: italic; font-size: 22px; line-height: 1.45; margin-top: 28px; margin-bottom: 32px; max-width: 520px; opacity: 0.9;">
            Zwanzig Jahre Gourmetküche. Ein Michelin-Stern. 16 GaultMillau-Punkte. Und immer noch das Lagerfeuer aus dem Pfadilager im Kopf.
          </p>
          <p style="font-size: 15px; line-height: 1.7; max-width: 480px; opacity: 0.75;">
            Aufgewachsen in Graubünden, geformt in den grössten Küchen der Schweiz, zurückgekehrt in die Bündner Herrschaft. Im Restaurant Pinot kocht Sebastian Titz eine Küche, die das Terroir kennt — und den Gast respektiert.
          </p>
          <div style="margin-top: 48px; display: flex; gap: 16px;">
            <a href="#stationen" class="tz-btn ember">Stationen ansehen <TzArrow /></a>
            <a href="#philo" class="tz-btn ghost" style="border-color: #f4efe7; color: #f4efe7;">Philosophie lesen</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── SIGNATURE DISHES ──────────────────────── -->
    <section style="padding: 120px 56px;">
      <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 64px;">
        <div>
          <div class="tz-eyebrow" style="margin-bottom: 16px;">§ 03 — Signature Dishes</div>
          <h2 class="tz-display" style="font-size: 88px; margin: 0; font-weight: 300;">
            Die <span class="it" style="font-style: italic;">Sprache</span> des Tellers.
          </h2>
        </div>
        <div style="display: flex; gap: 10px;">
          <button class="tz-btn ghost" style="width: 48px; height: 48px; padding: 0; justify-content: center;">←</button>
          <button class="tz-btn primary" style="width: 48px; height: 48px; padding: 0; justify-content: center;">→</button>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px;">
        {data.signatureDishes?.map((dish, index) => (
          <article style="border-top: 1px solid var(--ink); padding-top: 16px;">
            <div style="display: flex; justify-content: space-between; font-family: var(--mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 16px;">
              <span style={dish.tag?.toLowerCase() === 'signature' ? "color: var(--ember);" : "color: var(--ink-3);"}>● {dish.tag}</span>
              <span>№ 0{index + 1}</span>
            </div>
            <div style="aspect-ratio: 4/5; background: var(--paper-2); margin-bottom: 20px; overflow: hidden;">
              <img src={dish.image} alt="" style="width: 100%; height: 100%; object-fit: cover;" />
            </div>
            <h3 class="tz-display" style="font-size: 26px; margin: 0 0 10px; font-weight: 400; line-height: 1.1;">{dish.title}</h3>
            <p style="font-size: 13px; line-height: 1.55; color: var(--ink-3); margin: 0 0 14px;">{dish.description}</p>
            <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; color: var(--ink-4); text-transform: uppercase;">{dish.bottomTag}</div>
          </article>
        ))}
      </div>
    </section>

    <!-- ─── AKTUELLES ────────────────────────────── -->
    <section style="background: var(--paper-2); padding: 120px 56px;">
      <div style="display: grid; grid-template-columns: 340px 1fr; gap: 80px;">
        <div style="position: sticky; top: 40px; height: fit-content;">
          <div class="tz-eyebrow" style="margin-bottom: 16px;">§ 04 — Aktuelles</div>
          <h2 class="tz-display" style="font-size: 64px; margin: 0 0 24px; font-weight: 300; line-height: 0.95;">
            Presse &<br/><span class="it" style="font-style: italic;">Auszeichnungen</span>
          </h2>
          <p style="font-size: 14px; line-height: 1.65; color: var(--ink-3); max-width: 280px;">
            Im Laufe der Jahre wurde meine Art zu kochen nicht nur von geschätzten Gästen, sondern auch von etablierten Kritikern honoriert.
          </p>
        </div>
        <div>
          {data.news?.map((item) => (
            <article style="display: grid; grid-template-columns: 140px 1fr 40px; gap: 32px; padding: 28px 0; border-top: 1px solid var(--rule); align-items: start;">
              <div>
                <div style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; color: var(--ink-2);">{item.date}</div>
                <div style="font-family: var(--mono); font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ember-deep); margin-top: 6px;">{item.tag}</div>
              </div>
              <div>
                <div style="font-family: var(--serif); font-style: italic; font-size: 14px; color: var(--ink-3); margin-bottom: 6px;">{item.publisher}</div>
                <h3 class="tz-display" style="font-size: 32px; margin: 0 0 10px; font-weight: 400; line-height: 1.1;">{item.title}</h3>
                <p style="font-size: 14px; line-height: 1.55; color: var(--ink-3); margin: 0; max-width: 560px;">{item.description}</p>
              </div>
              <div style="align-self: center; font-size: 22px; color: var(--ink);">→</div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── ANGEBOTE ─────────────────────────────── -->
    <section style="padding: 120px 56px;">
      <div class="tz-eyebrow" style="margin-bottom: 16px;">§ 05 — Angebote</div>
      <h2 class="tz-display" style="font-size: 96px; margin: 0 0 64px; font-weight: 300;">
        Drei <span class="it" style="font-style: italic;">Wege</span>, gemeinsam zu kochen.
      </h2>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;">
        {data.offers?.map((offer, index) => (
          <div style={`padding: 32px; border: 1px solid var(--rule); background: ${offer.featured ? 'var(--ink)' : 'var(--paper)'}; color: ${offer.featured ? 'var(--paper)' : 'var(--ink)'}; display: flex; flex-direction: column; justify-content: space-between; min-height: 540px;`}>
            <div>
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                <div style={`font-family: var(--mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: ${offer.featured ? 'var(--ember)' : 'var(--ink-3)'};`}>№ 0{index + 1}</div>
                {offer.featured && <div style="font-family: var(--mono); font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ember);">● Flagship</div>}
              </div>
              <h3 class="tz-display" style="font-size: 48px; margin: 0 0 16px; font-weight: 400; line-height: 1;">{offer.title}</h3>
              <p style="font-family: var(--serif); font-size: 20px; font-style: italic; margin: 0 0 20px; line-height: 1.3; opacity: 0.9;">{offer.subtitle}</p>
              <p style="font-size: 14px; line-height: 1.6; opacity: 0.7; margin: 0;">{offer.description}</p>
            </div>
            <div>
              <div style="height: 180px; background: var(--paper-2); margin-top: 28px; margin-bottom: 24px; overflow: hidden;">
                <img src={offer.image} alt="" style="width: 100%; height: 100%; object-fit: cover;" />
              </div>
              <a class={`tz-btn ${offer.featured ? 'ember' : 'ghost'}`} href="#kontakt" style={!offer.featured ? "border-color: var(--ink);" : ""}>{offer.cta} <TzArrow /></a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ─── KONTAKT / PINOT ─────────────────────── -->
    <section id="pinot" style="background: var(--paper-3); padding: 120px 56px; position: relative; overflow: hidden;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px;">
        <div>
          <div class="tz-eyebrow" style="margin-bottom: 16px;">§ 06 — Besuchen Sie uns</div>
          <h2 class="tz-display" style="font-size: 88px; margin: 0 0 40px; font-weight: 300; line-height: 0.95;">
            Restaurant<br/><span class="it" style="font-style: italic; color: var(--ember-deep);">Pinot.</span>
          </h2>
          <p style="font-family: var(--serif); font-size: 22px; font-style: italic; line-height: 1.4; margin-bottom: 48px; max-width: 440px; color: var(--ink-2);">
            Erleben Sie meine neue Küche — in der Bündner Herrschaft, zwischen Reben und Alpen.
          </p>

          <div id="kontakt" style="display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-bottom: 48px; scroll-margin-top: 60px;">
            <div>
              <div class="tz-eyebrow" style="margin-bottom: 10px;">Adresse</div>
              <div style="font-family: var(--serif); font-size: 18px; line-height: 1.5; white-space: pre-wrap;">
                {data.restaurant?.address}
              </div>
            </div>
            <div>
              <div class="tz-eyebrow" style="margin-bottom: 10px;">Öffnungszeiten</div>
              <div style="font-family: var(--serif); font-size: 18px; line-height: 1.5; white-space: pre-wrap;">
                {data.restaurant?.hours}
              </div>
            </div>
            <div>
              <div class="tz-eyebrow" style="margin-bottom: 10px;">Telefon</div>
              <div style="font-family: var(--serif); font-size: 18px;">{data.restaurant?.phone}</div>
            </div>
            <div>
              <div class="tz-eyebrow" style="margin-bottom: 10px;">E-Mail</div>
              <div style="font-family: var(--serif); font-size: 18px;">{data.restaurant?.email}</div>
            </div>
          </div>

          <div style="display: flex; gap: 12px;">
            <a class="tz-btn primary" href="mailto:info@titz.cooking">Kontakt aufnehmen <TzArrow /></a>
            <a class="tz-btn ghost" href="#">Anfahrt ansehen</a>
          </div>
        </div>

        <div style="display: grid; grid-template-rows: 1fr 1fr; gap: 16px;">
          <div style="overflow: hidden; position: relative;">
            <img src={data.restaurant?.gallery?.[0]} alt="" style="width: 100%; height: 100%; object-fit: cover;" />
            <div style="position: absolute; bottom: 16px; left: 16px; font-family: var(--mono); font-size: 9px; letter-spacing: 0.2em; color: #f4efe7;">SOMMERTERRASSE</div>
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div style="overflow: hidden;"><img src={data.restaurant?.gallery?.[1]} alt="" style="width: 100%; height: 100%; object-fit: cover;" /></div>
            <div style="overflow: hidden;"><img src={data.restaurant?.gallery?.[2]} alt="" style="width: 100%; height: 100%; object-fit: cover;" /></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── MARQUEE / TICKER ────────────────────── -->
    <section style="border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); overflow: hidden; padding: 32px 0; background: var(--paper);">
      <div class="tz-marquee-track tz-display" style="font-size: 72px; font-weight: 300;">
        <span>Authentisch</span><span style="color: var(--ember);">●</span><span style="font-style: italic;">Regional</span><span style="color: var(--ember);">●</span><span>Exzellent</span><span style="color: var(--ember);">●</span>
        <span>Authentisch</span><span style="color: var(--ember);">●</span><span style="font-style: italic;">Regional</span><span style="color: var(--ember);">●</span><span>Exzellent</span><span style="color: var(--ember);">●</span>
      </div>
    </section>

    <TzFooter />
  </div>
</Layout>
