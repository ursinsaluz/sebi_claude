---
import Layout from '../layouts/Layout.astro';
import TzNav from '../components/TzNav.astro';
import TzFooter from '../components/TzFooter.astro';
import TzArrow from '../components/TzArrow.astro';
---

<Layout title="titz.cooking — Redesign">
  <div class="tz-root" style="min-height: 2400px; background: var(--paper); position: relative; overflow: hidden;">
    <!-- Nav — sits on hero image -->
    <div style="position: absolute; top: 0; left: 0; right: 0; z-index: 20;">
      <TzNav current="home" dark={true} />
    </div>

    <!-- ─── HERO ─────────────────────────────────── -->
    <section style="position: relative; height: 860px; overflow: hidden; background: #1a1a18;">
      <img src="/img/pinot-11.jpg" alt="" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.78;" />
      <div style="position: absolute; inset: 0; background: linear-gradient(180deg, rgba(26,26,24,0.55) 0%, rgba(26,26,24,0.15) 35%, rgba(26,26,24,0.75) 100%);"></div>

      <!-- Hero text -->
      <div style="position: absolute; left: 56px; right: 56px; bottom: 80px; color: #f4efe7;">
        <div style="display: grid; grid-template-columns: 1fr auto; align-items: flex-end; gap: 48px;">
          <div>
            <div class="tz-eyebrow" style="color: rgba(244,239,231,0.7); margin-bottom: 24px;">
              <span style="color: var(--ember);">●</span>&nbsp;&nbsp;Küchenchef · Restaurant Pinot · Fläsch
            </div>
            <h1 class="tz-display" style="font-size: 168px; margin: 0; line-height: 0.88; font-weight: 300;">
              Authentisch.<br/>
              <span class="it" style="font-style: italic; font-weight: 400;">Regional.</span><br/>
              <span style="color: var(--ember);">Exzellent.</span>
            </h1>
          </div>
          <div style="text-align: right; padding-bottom: 20px;">
            <p style="font-family: var(--serif); font-size: 20px; font-style: italic; line-height: 1.4; max-width: 340px; font-weight: 300; margin: 0; opacity: 0.9;">
              Kulinarik zwischen Michelin-Stern und Bündner Bodenständigkeit.
            </p>
            <div style="display: flex; gap: 12px; margin-top: 28px; justify-content: flex-end;">
              <a class="tz-btn ember" href="#philo">Meine Philosophie <TzArrow /></a>
              <a class="tz-btn ghost" href="#kontakt" style="border-color: #f4efe7; color: #f4efe7;">Kontakt aufnehmen</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Corner marks -->
      <div style="position: absolute; top: 120px; left: 56px; font-family: var(--mono); font-size: 10px; letter-spacing: 0.2em; color: rgba(244,239,231,0.55);">
        46°59′N · 09°31′E
      </div>
      <div style="position: absolute; top: 120px; right: 56px; font-family: var(--mono); font-size: 10px; letter-spacing: 0.2em; color: rgba(244,239,231,0.55); text-align: right;">
        EST. MMXXIV<br/>Nº 001
      </div>
    </section>

    <!-- ─── Auszeichnungen bar ─────────────────────── -->
    <section style="border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); background: var(--paper);">
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); padding: 36px 56px;">
        <!-- Array items hardcoded -->
        <div style="display: flex; align-items: baseline; gap: 20px; padding-left: 0; border-left: none;">
          <div class="tz-display" style="font-size: 64px; font-weight: 300; line-height: 1;">16</div>
          <div>
            <div style="font-family: var(--serif); font-size: 16px; font-style: italic;">GaultMillau</div>
            <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-3); margin-top: 4px;">Punkte 2024</div>
          </div>
        </div>
        <div style="display: flex; align-items: baseline; gap: 20px; padding-left: 40px; border-left: 1px solid var(--rule-soft);">
          <div class="tz-display" style="font-size: 64px; font-weight: 300; line-height: 1;">1★</div>
          <div>
            <div style="font-family: var(--serif); font-size: 16px; font-style: italic;">Michelin Stern</div>
            <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-3); margin-top: 4px;">Verve · Rössli · Jörg Müller</div>
          </div>
        </div>
        <div style="display: flex; align-items: baseline; gap: 20px; padding-left: 40px; border-left: 1px solid var(--rule-soft);">
          <div class="tz-display" style="font-size: 64px; font-weight: 300; line-height: 1;">Bib</div>
          <div>
            <div style="font-family: var(--serif); font-size: 16px; font-style: italic;">Gourmand</div>
            <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-3); margin-top: 4px;">Restaurant Pinot 2024</div>
          </div>
        </div>
        <div style="display: flex; align-items: baseline; gap: 20px; padding-left: 40px; border-left: 1px solid var(--rule-soft);">
          <div class="tz-display" style="font-size: 64px; font-weight: 300; line-height: 1;">20</div>
          <div>
            <div style="font-family: var(--serif); font-size: 16px; font-style: italic;">Jahre</div>
            <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-3); margin-top: 4px;">in der Gourmetgastronomie</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── PHILOSOPHIE ───────────────────────────── -->
    <section id="philo" style="padding: 140px 56px 120px; position: relative;">
      <div style="display: grid; grid-template-columns: 340px 1fr; gap: 80px; margin-bottom: 80px;">
        <div>
          <div class="tz-eyebrow" style="margin-bottom: 16px;">§ 01 — Philosophie</div>
          <div style="font-family: var(--mono); font-size: 11px; color: var(--ink-3); line-height: 1.7;">
            Drei Worte, die alles sagen.<br/>
            Drei Prinzipien, die bleiben.
          </div>
        </div>
        <h2 class="tz-display" style="font-size: 96px; margin: 0; font-weight: 300; max-width: 900px;">
          Kochen ist für mich ein <span class="it" style="font-style: italic;">tiefer Respekt</span> vor dem Ursprung unserer Nahrung.
        </h2>
      </div>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 48px; border-top: 1px solid var(--rule); padding-top: 48px;">
        <div>
          <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.2em; color: var(--ember); margin-bottom: 24px;">§ 01</div>
          <div style="height: 300px; background: var(--paper-2); margin-bottom: 28px; overflow: hidden;">
            <img src="/img/pinot-07.jpg" alt="" style="width: 100%; height: 100%; object-fit: cover; filter: saturate(0.95);" />
          </div>
          <h3 class="tz-display" style="font-size: 40px; margin: 0 0 12px; font-weight: 400;">Authentisch</h3>
          <p style="font-family: var(--serif); font-size: 17px; font-style: italic; color: var(--ink-2); margin: 0 0 16px; line-height: 1.4;">Ehrlich und ohne Schnickschnack.</p>
          <p style="font-size: 14px; line-height: 1.65; color: var(--ink-3); margin: 0;">Ich koche so, wie ich bin: bodenständig und direkt. Schnörkellose Gerichte, ohne Chichi, aber mit einem echten Wow-Effekt im Mund.</p>
        </div>
        <div>
          <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.2em; color: var(--ember); margin-bottom: 24px;">§ 02</div>
          <div style="height: 300px; background: var(--paper-2); margin-bottom: 28px; overflow: hidden;">
            <img src="/img/terroir-1.jpg" alt="" style="width: 100%; height: 100%; object-fit: cover; filter: saturate(0.95);" />
          </div>
          <h3 class="tz-display" style="font-size: 40px; margin: 0 0 12px; font-weight: 400;">Regional</h3>
          <p style="font-family: var(--serif); font-size: 17px; font-style: italic; color: var(--ink-2); margin: 0 0 16px; line-height: 1.4;">Aus der Heimat auf den Teller.</p>
          <p style="font-size: 14px; line-height: 1.65; color: var(--ink-3); margin: 0;">Die besten Lebensmittel finde ich direkt hier. Enge Zusammenarbeit mit lokalen Produzenten — gekocht wird frisch und im Rhythmus der vier Jahreszeiten.</p>
        </div>
        <div>
          <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.2em; color: var(--ember); margin-bottom: 24px;">§ 03</div>
          <div style="height: 300px; background: var(--paper-2); margin-bottom: 28px; overflow: hidden;">
            <img src="/img/dish-2.jpg" alt="" style="width: 100%; height: 100%; object-fit: cover; filter: saturate(0.95);" />
          </div>
          <h3 class="tz-display" style="font-size: 40px; margin: 0 0 12px; font-weight: 400;">Exzellent</h3>
          <p style="font-family: var(--serif); font-size: 17px; font-style: italic; color: var(--ink-2); margin: 0 0 16px; line-height: 1.4;">Die Natur als Massstab.</p>
          <p style="font-size: 14px; line-height: 1.65; color: var(--ink-3); margin: 0;">Der Goldene Schnitt. Die Fibonacci-Reihe. Natürliche Ordnung inspiriert mich beim Anrichten — bis daraus mit einem guten Glas Wein ein Erlebnis wird.</p>
        </div>
      </div>
    </section>

    <!-- ─── EDITORIAL SPREAD — the chef ───────────── -->
    <section style="background: var(--ink); color: var(--paper); padding: 120px 56px;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;">
        <div style="height: 620px; overflow: hidden; position: relative;">
          <img src="/img/pinot-15.jpg" alt="" style="width: 100%; height: 100%; object-fit: cover;" />
          <div style="position: absolute; bottom: 16px; left: 16px; font-family: var(--mono); font-size: 9px; letter-spacing: 0.2em; color: #f4efe7; opacity: 0.7;">
            FIG. 01 — In der Küche, Restaurant Pinot, Fläsch
          </div>
        </div>
        <div>
          <div class="tz-eyebrow" style="color: var(--ember); margin-bottom: 24px;">§ 02 — Der Koch</div>
          <h2 class="tz-display" style="font-size: 72px; margin: 0; font-weight: 300; line-height: 0.98;">
            Sebastian <span class="it" style="font-style: italic; color: var(--ember);">Titz</span>
          </h2>
          <p style="font-family: var(--serif); font-style: italic; font-size: 22px; line-height: 1.45; margin-top: 28px; margin-bottom: 32px; max-width: 520px; opacity: 0.9;">
            Zwanzig Jahre Gourmetküche. Ein Michelin-Stern. 16 GaultMillau-Punkte. Und immer noch das Lagerfeuer aus dem Pfadilager im Kopf.
          </p>
          <p style="font-size: 15px; line-height: 1.7; max-width: 480px; opacity: 0.75;">
            Aufgewachsen in Graubünden, geformt in den grössten Küchen der Schweiz, zurückgekehrt in die Bündner Herrschaft. Im Restaurant Pinot kocht Sebastian Titz eine Küche, die das Terroir kennt — und den Gast respektiert.
          </p>
          <div style="margin-top: 48px; display: flex; gap: 16px;">
            <a href="#stationen" class="tz-btn ember">Stationen ansehen <TzArrow /></a>
            <a href="#philo" class="tz-btn ghost" style="border-color: #f4efe7; color: #f4efe7;">Philosophie lesen</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── SIGNATURE DISHES ──────────────────────── -->
    <section style="padding: 120px 56px;">
      <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 64px;">
        <div>
          <div class="tz-eyebrow" style="margin-bottom: 16px;">§ 03 — Signature Dishes</div>
          <h2 class="tz-display" style="font-size: 88px; margin: 0; font-weight: 300;">
            Die <span class="it" style="font-style: italic;">Sprache</span> des Tellers.
          </h2>
        </div>
        <div style="display: flex; gap: 10px;">
          <button class="tz-btn ghost" style="width: 48px; height: 48px; padding: 0; justify-content: center;">←</button>
          <button class="tz-btn primary" style="width: 48px; height: 48px; padding: 0; justify-content: center;">→</button>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px;">
        <article style="border-top: 1px solid var(--ink); padding-top: 16px;">
          <div style="display: flex; justify-content: space-between; font-family: var(--mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 16px;">
            <span style="color: var(--ember);">● signature</span>
            <span>№ 01</span>
          </div>
          <div style="aspect-ratio: 4/5; background: var(--paper-2); margin-bottom: 20px; overflow: hidden;">
            <img src="/img/dish-1.jpg" alt="" style="width: 100%; height: 100%; object-fit: cover;" />
          </div>
          <h3 class="tz-display" style="font-size: 26px; margin: 0 0 10px; font-weight: 400; line-height: 1.1;">Milcheis mit Spekulatius</h3>
          <p style="font-size: 13px; line-height: 1.55; color: var(--ink-3); margin: 0 0 14px;">Winterliche Aromen treffen auf Finesse. Geflämmte Meringue, Apfel, Spekulatius.</p>
          <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; color: var(--ink-4); text-transform: uppercase;">Dessert · Winter</div>
        </article>
        <article style="border-top: 1px solid var(--ink); padding-top: 16px;">
          <div style="display: flex; justify-content: space-between; font-family: var(--mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 16px;">
            <span style="color: var(--ember);">● signature</span>
            <span>№ 02</span>
          </div>
          <div style="aspect-ratio: 4/5; background: var(--paper-2); margin-bottom: 20px; overflow: hidden;">
            <img src="/img/moor-1.jpg" alt="" style="width: 100%; height: 100%; object-fit: cover;" />
          </div>
          <h3 class="tz-display" style="font-size: 26px; margin: 0 0 10px; font-weight: 400; line-height: 1.1;">Heusuppe</h3>
          <p style="font-size: 13px; line-height: 1.55; color: var(--ink-3); margin: 0 0 14px;">Hommage an Stefan Wiesner. Getrocknetes Heu in einer samtigen Suppe. Natur pur.</p>
          <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; color: var(--ink-4); text-transform: uppercase;">Suppe · Ganzjährig</div>
        </article>
        <article style="border-top: 1px solid var(--ink); padding-top: 16px;">
          <div style="display: flex; justify-content: space-between; font-family: var(--mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 16px;">
            <span style="color: var(--ink-3);">● starter</span>
            <span>№ 03</span>
          </div>
          <div style="aspect-ratio: 4/5; background: var(--paper-2); margin-bottom: 20px; overflow: hidden;">
            <img src="/img/dish-3.jpg" alt="" style="width: 100%; height: 100%; object-fit: cover;" />
          </div>
          <h3 class="tz-display" style="font-size: 26px; margin: 0 0 10px; font-weight: 400; line-height: 1.1;">Angus Beef Tartare</h3>
          <p style="font-size: 13px; line-height: 1.55; color: var(--ink-3); margin: 0 0 14px;">Hommage an die Erde. Das Rohe des Rindes trifft auf die Textur des Selleries.</p>
          <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; color: var(--ink-4); text-transform: uppercase;">Vorspeise</div>
        </article>
        <article style="border-top: 1px solid var(--ink); padding-top: 16px;">
          <div style="display: flex; justify-content: space-between; font-family: var(--mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 16px;">
            <span style="color: var(--ember);">● signature</span>
            <span>№ 04</span>
          </div>
          <div style="aspect-ratio: 4/5; background: var(--paper-2); margin-bottom: 20px; overflow: hidden;">
            <img src="/img/dish-4.jpg" alt="" style="width: 100%; height: 100%; object-fit: cover;" />
          </div>
          <h3 class="tz-display" style="font-size: 26px; margin: 0 0 10px; font-weight: 400; line-height: 1.1;">Kalb mit schwarzem Trüffel</h3>
          <p style="font-size: 13px; line-height: 1.55; color: var(--ink-3); margin: 0 0 14px;">Heimat trifft Luxus. Zartes Kalb, Tiefe des Trüffels, Serviettenknödel.</p>
          <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; color: var(--ink-4); text-transform: uppercase;">Hauptgang · Winter</div>
        </article>
      </div>
    </section>

    <!-- ─── AKTUELLES ────────────────────────────── -->
    <section style="background: var(--paper-2); padding: 120px 56px;">
      <div style="display: grid; grid-template-columns: 340px 1fr; gap: 80px;">
        <div style="position: sticky; top: 40px; height: fit-content;">
          <div class="tz-eyebrow" style="margin-bottom: 16px;">§ 04 — Aktuelles</div>
          <h2 class="tz-display" style="font-size: 64px; margin: 0 0 24px; font-weight: 300; line-height: 0.95;">
            Presse &<br/><span class="it" style="font-style: italic;">Auszeichnungen</span>
          </h2>
          <p style="font-size: 14px; line-height: 1.65; color: var(--ink-3); max-width: 280px;">
            Im Laufe der Jahre wurde meine Art zu kochen nicht nur von geschätzten Gästen, sondern auch von etablierten Kritikern honoriert.
          </p>
        </div>
        <div>
          <article style="display: grid; grid-template-columns: 140px 1fr 40px; gap: 32px; padding: 28px 0; border-top: 1px solid var(--rule); align-items: start;">
            <div>
              <div style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; color: var(--ink-2);">02.01.2026</div>
              <div style="font-family: var(--mono); font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ember-deep); margin-top: 6px;">Auszeichnung</div>
            </div>
            <div>
              <div style="font-family: var(--serif); font-style: italic; font-size: 14px; color: var(--ink-3); margin-bottom: 6px;">Falstaff</div>
              <h3 class="tz-display" style="font-size: 32px; margin: 0 0 10px; font-weight: 400; line-height: 1.1;">Restaurants & Beizen Guide 2026</h3>
              <p style="font-size: 14px; line-height: 1.55; color: var(--ink-3); margin: 0; max-width: 560px;">Das Restaurant Pinot wurde von Falstaff Schweiz ausgezeichnet — für regionale Küche und die kreative Handschrift von Sebastian.</p>
            </div>
            <div style="align-self: center; font-size: 22px; color: var(--ink);">→</div>
          </article>
          <article style="display: grid; grid-template-columns: 140px 1fr 40px; gap: 32px; padding: 28px 0; border-top: 1px solid var(--rule); align-items: start;">
            <div>
              <div style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; color: var(--ink-2);">21.10.2025</div>
              <div style="font-family: var(--mono); font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ember-deep); margin-top: 6px;">Interview</div>
            </div>
            <div>
              <div style="font-family: var(--serif); font-style: italic; font-size: 14px; color: var(--ink-3); margin-bottom: 6px;">Podcast · Was kochst du?!</div>
              <h3 class="tz-display" style="font-size: 32px; margin: 0 0 10px; font-weight: 400; line-height: 1.1;">Im Gespräch mit Andy Piesche & Felix Jarzina</h3>
              <p style="font-size: 14px; line-height: 1.55; color: var(--ink-3); margin: 0; max-width: 560px;">Drei Chefs über Küche, Handwerk und den Mut zum Weglassen.</p>
            </div>
            <div style="align-self: center; font-size: 22px; color: var(--ink);">→</div>
          </article>
        </div>
      </div>
    </section>

    <!-- ─── ANGEBOTE ─────────────────────────────── -->
    <section style="padding: 120px 56px;">
      <div class="tz-eyebrow" style="margin-bottom: 16px;">§ 05 — Angebote</div>
      <h2 class="tz-display" style="font-size: 96px; margin: 0 0 64px; font-weight: 300;">
        Drei <span class="it" style="font-style: italic;">Wege</span>, gemeinsam zu kochen.
      </h2>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;">
        <div style="padding: 32px; border: 1px solid var(--rule); background: var(--paper); color: var(--ink); display: flex; flex-direction: column; justify-content: space-between; min-height: 540px;">
          <div>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
              <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-3);">№ 01</div>
            </div>
            <h3 class="tz-display" style="font-size: 48px; margin: 0 0 16px; font-weight: 400; line-height: 1;">Beratung</h3>
            <p style="font-family: var(--serif); font-size: 20px; font-style: italic; margin: 0 0 20px; line-height: 1.3; opacity: 0.9;">Kulinarische Konzepte für Health- & Lifestyle-Resorts.</p>
            <p style="font-size: 14px; line-height: 1.6; opacity: 0.7; margin: 0;">Zwanzig Jahre Gourmetgastronomie, übersetzt in tragfähige Konzepte — vom Menü-Engineering bis zur Teamführung.</p>
          </div>
          <div>
            <div style="height: 180px; background: var(--paper-2); margin-top: 28px; margin-bottom: 24px; overflow: hidden;">
              <img src="/img/pinot-18.jpg" alt="" style="width: 100%; height: 100%; object-fit: cover;" />
            </div>
            <a class="tz-btn ghost" href="#kontakt" style="border-color: var(--ink);">Beratung anfragen <TzArrow /></a>
          </div>
        </div>
        <div style="padding: 32px; border: 1px solid var(--rule); background: var(--paper); color: var(--ink); display: flex; flex-direction: column; justify-content: space-between; min-height: 540px;">
          <div>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
              <div style="font-family: var(--mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-3);">№ 02</div>
            </div>
            <h3 class="tz-display" style="font-size: 48px; margin: 0 0 16px; font-weight: 400; line-height: 1;">Catering</h3>
            <p style="font-family: var(--serif); font-size: 20px; font-style: italic; margin: 0 0 20px; line-height: 1.3; opacity: 0.9;">Nachhaltige Sternenküche für Ihren Event.</p>
            <p style="font-size: 14px; line-height: 1.6; opacity: 0.7; margin: 0;">Wir bringen exzellenten Genuss zu Ihnen — vom privaten Dinner bis zum Firmen-Anlass, stets mit regionalem Fokus.</p>
          </div>
          <div>
            <div style="height: 180px; background: var(--paper-2); margin-top: 28px; margin-bottom: 24px; overflow: hidden;">
