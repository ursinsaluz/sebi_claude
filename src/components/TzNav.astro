---
import TzLogo from './TzLogo.astro';
import TzArrow from './TzArrow.astro';
import { tinaField } from 'tinacms/dist/react';

export interface Props {
  current?: string;
  dark?: boolean;
  compact?: boolean;
  navItems?: { id: string; label: string; href: string }[];
  cta?: { label: string; href: string };
  tinaData?: any;
}

const { current = 'home', dark = false, compact = false, navItems = [], cta, tinaData } = Astro.props;

const ink = dark ? '#f4efe7' : 'var(--ink)';
---
<nav style={`
  display: flex; align-items: center; justify-content: space-between;
  padding: ${compact ? '18px 32px' : '28px 56px'}; color: ${ink};
  border-bottom: ${dark ? '1px solid rgba(244,239,231,0.15)' : '1px solid var(--rule-soft)'}
`}>
  <TzLogo size={compact ? 17 : 19} color={ink} />
  <div style="display: flex; gap: 34px; font-family: var(--sans); font-size: 13px; letter-spacing: 0.01em;" data-tina-field={tinaData ? tinaField(tinaData, 'nav') : ''}>
    {navItems.map((it, i) => (
      <a href={it.href} style={`
        color: ${ink}; text-decoration: none;
        opacity: ${current === it.id ? 1 : 0.7};
        border-bottom: ${current === it.id ? `1px solid ${dark ? 'var(--ember)' : 'var(--ink)'}` : '1px solid transparent'};
        padding-bottom: 3px;
      `} data-tina-field={tinaData ? tinaField(tinaData.nav[i], 'label') : ''}>{it.label}</a>
    ))}
  </div>
  <div style="display: flex; align-items: center; gap: 16px;">
    {cta && (
      <a href={cta.href} class="tz-btn primary" style={`
        padding: 10px 18px; font-size: 12px;
        background: ${dark ? 'var(--ember)' : 'var(--ink)'};
        color: ${dark ? '#f4efe7' : 'var(--paper)'}
      `} data-tina-field={tinaData ? tinaField(tinaData.cta, 'label') : ''}>
        {cta.label} <TzArrow size={12} />
      </a>
    )}
  </div>
</nav>
